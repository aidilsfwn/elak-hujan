# MET Malaysia API token (api.met.gov.my)
# Register at https://api.met.gov.my to get your token.
# This is a SERVER-SIDE variable — never prefixed with VITE_.
# In production: add MET_TOKEN to your Vercel environment variables.
# In local dev: add to .env.local (Vite loads it for the dev proxy).
MET_TOKEN=your_token_here
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here